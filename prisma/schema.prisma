generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model user {
  id          Int        @id @default(autoincrement())
  name        String
  email       String     @unique
  password    String
  age         Int
  description String?
  createdAt   DateTime   @default(now())
  user_role   USER_ROLES @default(NORMAL)

  borrow_records borrow_record[]
}

model book {
  id               Int    @id @default(autoincrement())
  title            String
  author           String
  total_copies     Int
  available_copies Int

  borrow_records borrow_record[]
}

model borrow_record {
  borrow_record_id Int           @id @default(autoincrement())
  borrow_date      DateTime      @default(now())
  borrow_days      Int
  return_date      DateTime?
  status           borrow_status

  user    user @relation(fields: [user_id], references: [id])
  user_id Int
  book    book @relation(fields: [book_id], references: [id])
  book_id Int
}

enum borrow_status {
  BORROWED
  RETURNED
  LATE
}

enum USER_ROLES {
  NORMAL
  ADMIN
}
