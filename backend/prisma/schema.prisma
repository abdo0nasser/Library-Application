generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model user {
  id                Int        @id @default(autoincrement())
  name              String
  email             String     @unique
  password          String
  age               Int?
  description       String?
  user_profile      String?
  createdAt         DateTime   @default(now())
  user_role         USER_ROLES @default(NORMAL)
  email_verified_at DateTime?
  facebook_id       String?    @unique

  borrow_records borrow_record[]
  books          book[]

  @@index([email])
  @@index([facebook_id])
}

model book {
  id               Int    @id @default(autoincrement())
  title            String
  author           String
  total_copies     Int
  available_copies Int

  user    user @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int

  borrow_records borrow_record[]
}

model borrow_record {
  borrow_record_id Int           @id @default(autoincrement())
  borrow_date      DateTime      @default(now())
  borrow_days      Int
  return_date      DateTime?
  status           borrow_status

  user    user @relation(fields: [user_id], references: [id], onDelete: Cascade)
  user_id Int
  book    book @relation(fields: [book_id], references: [id], onDelete: Cascade)
  book_id Int
}

enum borrow_status {
  BORROWED
  RETURNED
  LATE
}

enum USER_ROLES {
  NORMAL
  ADMIN
}
